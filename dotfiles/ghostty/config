theme = stylix
background-opacity = 0.95
# font-family = "Hack Nerd Font Mono Regular"
# font-family = "ZedMono NFM"  # retired: geometric/symbol glyphs overflow the cell in Ghostty
# font-size = 10
font-family = "Pragmasevka Nerd Font"
# Let Ghostty send the standard kitty keyboard protocol sequence for shift+enter
# keybind = shift+enter=esc:SE
keybind = global:cmd+ctrl+t=toggle_quick_terminal

# Workaround: Ghostty 1.3.1's modifyOtherKeys mode 2 doesn't disambiguate
# Ctrl+digit (verified empirically — `printf '\e[>4;2m'; cat -v` followed
# by Ctrl+1 still emits literal `1`). tmux can't bind C-1..9 without the
# disambiguated sequences. Send them ourselves via the CSI u (libtickit)
# format — tmux accepts CSI u when extended-keys=on + extkeys feature,
# which our tmux.nix already configures. Apps that don't understand
# CSI u just ignore the escape, so this is harmless outside tmux.
# Revisit once Ghostty's modifyOtherKeys mode 2 covers digits (file
# upstream first — see TODO.md).
# Standard macOS copy behaviour: drag selects but doesn't auto-copy;
# Cmd+C copies the current selection (Ghostty's default binding does
# this). The Cmd+C-with-no-selection fall-through into Meta+C / `\ec`
# is silenced on the fish side (see fish.nix's `fish_user_key_bindings`).
copy-on-select = false

keybind = ctrl+1=csi:49;5u
keybind = ctrl+2=csi:50;5u
keybind = ctrl+3=csi:51;5u
keybind = ctrl+4=csi:52;5u
keybind = ctrl+5=csi:53;5u
keybind = ctrl+6=csi:54;5u
keybind = ctrl+7=csi:55;5u
keybind = ctrl+8=csi:56;5u
keybind = ctrl+9=csi:57;5u
quick-terminal-space-behavior = move
shell-integration-features = no-cursor,sudo,ssh-terminfo,ssh-env
